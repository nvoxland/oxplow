#!/usr/bin/env bash
set -e
DIR="$(cd "$(dirname "$0")/.." && pwd)"
if [ ! -f "$DIR/dist/electron-main.cjs" ]; then
  echo "[oxplow] missing Electron build output. Run 'bun run build' first." >&2
  exit 1
fi

if [ ! -x "$DIR/node_modules/.bin/electron" ]; then
  echo "[oxplow] electron is not installed. Run 'bun install' first." >&2
  exit 1
fi

exec "$DIR/node_modules/.bin/electron" "$DIR" --project "$PWD" "$@"
