{
  "name": "newde",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/electron-main.cjs",
  "bin": {
    "newde": "./bin/newde"
  },
  "scripts": {
    "build:daemon": "bun build src/daemon.ts --target=node --outfile=dist/daemon.js --external node-pty",
    "build:ui": "bun build src/ui/main.tsx --outdir=public/dist --target=browser --format=esm --splitting",
    "build:electron-main": "bun build src/electron/main.ts --target=node --format=cjs --outfile=dist/electron-main.cjs --external electron --external node-pty",
    "build:electron-preload": "bun build src/electron/preload.ts --target=node --format=cjs --outfile=dist/electron-preload.cjs --external electron",
    "build": "bun run build:daemon && bun run build:ui && bun run build:electron-main && bun run build:electron-preload",
    "dev:electron": "bun run build && electron .",
    "start": "electron .",
    "test": "bun test"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "monaco-editor": "^0.55.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript-language-server": "^5.1.3",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "electron": "^41.2.1",
    "typescript": "^5.5.0"
  }
}
