{
  "name": "oxplow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": {
    "name": "Nathan Voxland",
    "email": "nathan@voxland.net"
  },
  "main": "./dist/electron-main.cjs",
  "bin": {
    "oxplow": "./bin/oxplow"
  },
  "scripts": {
    "build:ui": "bun build src/ui/main.tsx --outdir=public/dist --target=browser --format=esm --splitting",
    "build:electron-main": "bun build src/electron/main.ts --target=node --format=cjs --outfile=dist/electron-main.cjs --external electron --external node-pty",
    "build:electron-preload": "bun build src/electron/preload.ts --target=node --format=cjs --outfile=dist/electron-preload.cjs --external electron",
    "build": "bun run build:ui && bun run build:electron-main && bun run build:electron-preload",
    "dev:electron": "bun run build && electron .",
    "start": "electron .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bunx tsc --noEmit && bun test",
    "dist": "bun run build && electron-builder"
  },
  "build": {
    "appId": "com.voxland.oxplow",
    "productName": "Oxplow",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "bin/**/*",
      "package.json",
      "!**/*.md",
      "!**/*.markdown",
      "!**/CHANGELOG*",
      "!**/HISTORY*",
      "!**/AUTHORS*",
      "!**/CONTRIBUTORS*",
      "!**/test/**",
      "!**/tests/**",
      "!**/__tests__/**",
      "!**/*.test.*",
      "!**/*.spec.*",
      "!**/example/**",
      "!**/examples/**",
      "!**/docs/**",
      "!**/doc/**",
      "!**/.github/**",
      "!**/.vscode/**",
      "!**/.idea/**",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/tsconfig*.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Development"
    },
    "publish": [
      { "provider": "github" }
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "monaco-editor": "^0.55.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript-language-server": "^5.1.3",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1",
    "typescript": "^5.5.0"
  }
}
